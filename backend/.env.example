# Copy this file to .env and fill in the values for local development.
# .env is listed in .gitignore and will never be committed.

# HTTP --------------------------------------------------------------------
PORT=8080
# Comma-separated list of origins allowed by CORS.
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app (set this in Railway env vars)
ALLOWED_ORIGINS=http://localhost:3000

# Database ----------------------------------------------------------------
# Supabase -> Project Settings -> Database -> Connection string (URI).
# Use the "Session" pooler URL for long-running Go services.
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres?sslmode=disable

# Supabase Auth -----------------------------------------------------------
# Supabase -> Project Settings -> API -> JWT Settings -> JWT Secret.
SUPABASE_JWT_SECRET=change-me-in-local-dev
# Optional; when set, the "iss" claim must match.
# SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
# Expected "aud" claim. Supabase default is "authenticated".
SUPABASE_JWT_AUDIENCE=authenticated

# FX --------------------------------------------------------------------
# Optional override for the default fixed rates (base currency: JPY).
# Format: CODE=rate, comma-separated.
# FX_RATES=USD=150.25,EUR=162.10
