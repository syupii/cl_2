                    "type": "string",
                    "example": "Premium"
                },
                "price": {
                    "type": "string",
                    "example": "2290"
                },
                "service_name": {
                    "type": "string",
                    "example": "Netflix"
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "active",
                        "cancelled"
                    ],
                    "example": "active"
                },
                "updated_at": {
                    "type": "string",
                    "example": "2026-04-01T10:00:00Z"
